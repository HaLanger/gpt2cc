# Local Anthropic-compatible proxy listener.
CCPROXY_HOST=127.0.0.1
CCPROXY_PORT=3456

# Your Codex/OpenAI-compatible relay. Include /v1 if your relay expects it.
CCPROXY_UPSTREAM_BASE_URL=https://your-codex-relay.example.com/v1
CCPROXY_UPSTREAM_CHAT_PATH=/chat/completions
CCPROXY_UPSTREAM_IMAGES_GENERATIONS_PATH=/images/generations
CCPROXY_UPSTREAM_IMAGES_EDITS_PATH=/images/edits
CCPROXY_UPSTREAM_API_KEY=sk-your-upstream-key

# TLS verification for the upstream relay. Keep verification enabled when possible.
CCPROXY_UPSTREAM_SSL_VERIFY=true
# CCPROXY_UPSTREAM_CA_BUNDLE=C:\path\to\company-or-relay-ca.pem

# Map Claude Code's requested model to a model that your relay actually supports.
# You can also set CCPROXY_UPSTREAM_MODEL to force one upstream model for all requests.
CCPROXY_UPSTREAM_MODEL=gpt-4.1
# CCPROXY_MODEL_MAP={"claude-sonnet-4-5-20250929":"gpt-4.1","claude-3-5-sonnet-20241022":"gpt-4.1"}

# Optional key that Claude Code/ccswitch must send to this proxy.
# Leave empty for local-only testing.
CCPROXY_PROXY_API_KEY=

# Compatibility switches for different relays.
CCPROXY_TIMEOUT_SECONDS=600
CCPROXY_MAX_RETRIES=1
CCPROXY_STREAM_INCLUDE_USAGE=true
CCPROXY_RETRY_WITHOUT_STREAM_OPTIONS=true
CCPROXY_MAX_TOKENS_FIELD=max_tokens
CCPROXY_OMIT_TEMPERATURE=false
CCPROXY_OMIT_TOP_P=false

# Debugging. Do not enable payload logging if prompts may contain secrets.
CCPROXY_LOG_LEVEL=INFO
CCPROXY_DEBUG_PAYLOADS=false

# Image route. If CCPROXY_UPSTREAM_MODEL is gpt-image-2, ccproxy automatically
# calls /images/generations for text-only prompts and /images/edits when the
# Claude Code request contains reference image blocks.
CCPROXY_IMAGE_MODELS=gpt-image-*,dall-e-3,dall-e-2
CCPROXY_IMAGE_OUTPUT_DIR=generated-images
CCPROXY_IMAGE_SIZE=auto
CCPROXY_IMAGE_QUALITY=auto
CCPROXY_IMAGE_BACKGROUND=auto
CCPROXY_IMAGE_OUTPUT_FORMAT=png
CCPROXY_IMAGE_N=1
CCPROXY_IMAGE_INPUT_FIDELITY=
CCPROXY_IMAGE_MAX_REFERENCE_IMAGES=16
