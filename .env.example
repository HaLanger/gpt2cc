# Local Anthropic-compatible proxy listener.
GPT2CC_HOST=127.0.0.1
GPT2CC_PORT=3456

# Your Codex/OpenAI-compatible relay. Include /v1 if your relay expects it.
GPT2CC_UPSTREAM_BASE_URL=https://your-codex-relay.example.com/v1
GPT2CC_UPSTREAM_CHAT_PATH=/chat/completions
GPT2CC_UPSTREAM_IMAGES_GENERATIONS_PATH=/images/generations
GPT2CC_UPSTREAM_IMAGES_EDITS_PATH=/images/edits
GPT2CC_UPSTREAM_API_KEY=sk-your-upstream-key

# TLS verification for the upstream relay. Keep verification enabled when possible.
GPT2CC_UPSTREAM_SSL_VERIFY=true
# GPT2CC_UPSTREAM_CA_BUNDLE=C:\path\to\company-or-relay-ca.pem

# Map Claude Code's requested model to a model that your relay actually supports.
# You can also set GPT2CC_UPSTREAM_MODEL to force one upstream model for all requests.
GPT2CC_UPSTREAM_MODEL=gpt-4.1
# GPT2CC_MODEL_MAP={"claude-sonnet-4-5-20250929":"gpt-4.1","claude-3-5-sonnet-20241022":"gpt-4.1"}

# Optional key that Claude Code/ccswitch must send to this proxy.
# Leave empty for local-only testing.
GPT2CC_PROXY_API_KEY=

# Compatibility switches for different relays.
GPT2CC_TIMEOUT_SECONDS=600
GPT2CC_MAX_RETRIES=1
GPT2CC_STREAM_INCLUDE_USAGE=true
GPT2CC_RETRY_WITHOUT_STREAM_OPTIONS=true
GPT2CC_MAX_TOKENS_FIELD=max_tokens
GPT2CC_OMIT_TEMPERATURE=false
GPT2CC_OMIT_TOP_P=false

# Debugging. Do not enable payload logging if prompts may contain secrets.
GPT2CC_LOG_LEVEL=INFO
GPT2CC_DEBUG_PAYLOADS=false

# Image route. If GPT2CC_UPSTREAM_MODEL is gpt-image-2, gpt2cc automatically
# calls /images/generations for text-only prompts and /images/edits when the
# Claude Code request contains reference image blocks.
GPT2CC_IMAGE_MODELS=gpt-image-*,dall-e-3,dall-e-2
GPT2CC_IMAGE_OUTPUT_DIR=generated-images
GPT2CC_IMAGE_SIZE=auto
GPT2CC_IMAGE_QUALITY=auto
GPT2CC_IMAGE_BACKGROUND=auto
GPT2CC_IMAGE_OUTPUT_FORMAT=png
GPT2CC_IMAGE_N=1
GPT2CC_IMAGE_INPUT_FIDELITY=
GPT2CC_IMAGE_MAX_REFERENCE_IMAGES=16
