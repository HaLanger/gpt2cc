{
  "host": "127.0.0.1",
  "port": 3456,
  "active_provider": "main-relay",
  "active_model": "gpt-4.1",
  "model_routes": {
    "claude-opus-4-7": {"provider": "main-relay", "model": "gpt-4.1"},
    "claude-sonnet-4-6": {"provider": "main-relay", "model": "gpt-4.1"},
    "claude-haiku-4-5-20251001": {"provider": "gemini-relay", "model": "gemini-2.5-flash"}
  },
  "primary_route_model": "claude-sonnet-4-6",
  "providers": [
    {
      "id": "main-relay",
      "name": "Main OpenAI-compatible relay",
      "protocol": "openai",
      "upstream_base_url": "https://your-codex-relay.example.com/v1",
      "upstream_api_key": "sk-your-upstream-key",
      "models": ["gpt-4.1", "gpt-image-2"],
      "upstream_chat_path": "/chat/completions",
      "upstream_images_generations_path": "/images/generations",
      "upstream_images_edits_path": "/images/edits",
      "upstream_auth_header": "Authorization",
      "upstream_auth_scheme": "Bearer"
    },
    {
      "id": "anthropic-relay",
      "name": "Anthropic relay",
      "protocol": "anthropic",
      "upstream_base_url": "https://api.anthropic.com/v1",
      "upstream_api_key": "sk-ant-your-key",
      "models": ["claude-sonnet-4-5-20250929"],
      "upstream_messages_path": "/messages"
    },
    {
      "id": "gemini-relay",
      "name": "Gemini relay",
      "protocol": "gemini",
      "upstream_base_url": "https://generativelanguage.googleapis.com/v1beta",
      "upstream_api_key": "your-gemini-key",
      "models": ["gemini-2.5-pro", "gemini-2.5-flash"],
      "upstream_gemini_generate_path": "/models/{model}:generateContent",
      "upstream_gemini_stream_path": "/models/{model}:streamGenerateContent"
    }
  ],
  "provider_pricing": {
    "main-relay": {
      "gpt-4.1": {
        "input_per_million": 2.5,
        "output_per_million": 10.0,
        "cache_read_per_million": 0.3
      }
    }
  },
  "proxy_api_key": "local-claude-code-key",
  "upstream_ssl_verify": true,
  "upstream_ca_bundle": "",
  "timeout_seconds": 600,
  "max_retries": 1,
  "stream_include_usage": true,
  "retry_without_stream_options": true,
  "max_tokens_field": "max_tokens",
  "omit_temperature": false,
  "omit_top_p": false,
  "log_level": "INFO",
  "debug_payloads": false,
  "image_models": ["gpt-image-*", "dall-e-3", "dall-e-2"],
  "image_output_dir": "generated-images",
  "image_size": "auto",
  "image_quality": "auto",
  "image_background": "auto",
  "image_output_format": "png",
  "image_n": 1,
  "image_moderation": "",
  "image_input_fidelity": "",
  "image_max_reference_images": 16
}
