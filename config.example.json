{
  "host": "127.0.0.1",
  "port": 3456,
  "active_provider": "main-relay",
  "active_model": "gpt-4.1",
  "providers": [
    {
      "id": "main-relay",
      "name": "Main relay",
      "upstream_base_url": "https://your-codex-relay.example.com/v1",
      "upstream_api_key": "sk-your-upstream-key",
      "models": ["gpt-4.1", "gpt-image-2"],
      "upstream_chat_path": "/chat/completions",
      "upstream_images_generations_path": "/images/generations",
      "upstream_images_edits_path": "/images/edits",
      "upstream_auth_header": "Authorization",
      "upstream_auth_scheme": "Bearer"
    },
    {
      "id": "backup-relay",
      "name": "Backup relay",
      "upstream_base_url": "https://your-backup-relay.example.com/v1",
      "upstream_api_key": "sk-your-backup-key",
      "models": ["gpt-4.1-mini", "gpt-image-2"]
    }
  ],
  "proxy_api_key": "local-claude-code-key",
  "upstream_ssl_verify": true,
  "upstream_ca_bundle": "",
  "timeout_seconds": 600,
  "max_retries": 1,
  "stream_include_usage": true,
  "retry_without_stream_options": true,
  "max_tokens_field": "max_tokens",
  "omit_temperature": false,
  "omit_top_p": false,
  "log_level": "INFO",
  "debug_payloads": false,
  "image_models": ["gpt-image-*", "dall-e-3", "dall-e-2"],
  "image_output_dir": "generated-images",
  "image_size": "auto",
  "image_quality": "auto",
  "image_background": "auto",
  "image_output_format": "png",
  "image_n": 1,
  "image_moderation": "",
  "image_input_fidelity": "",
  "image_max_reference_images": 16
}
